{
  "name": "sj/adminpanel",
  "description": "Enterprise-grade Laravel 12 Admin Panel package with BREAD builder, Database manager, Media manager, and RBAC.",
  "type": "laravel-package",
  "license": "MIT",
  "authors": [
    {
      "name": "SJ Admin Team",
      "email": "shreenologyinfotech@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "SJ\\AdminPanel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SJ\\AdminPanel\\Providers\\AdminPanelServiceProvider"
      ],
      "aliases": {
        "AdminPanel": "SJ\\AdminPanel\\Facades\\AdminPanel"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}